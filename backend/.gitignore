# ─────────────────────────────────────────────────────────────────────────────
#  SVAS Backend – .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets & credentials (NEVER commit these) ────────────────────────────────
.env
.env.local
.env.*.local
serviceAccountKey.json
*serviceAccount*.json
*credentials*.json
*secret*.json
gcloud-key.json

# ── Python bytecode & caches ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/
.venv*/

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/
pip-wheel-metadata/
share/python-wheels/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.coveragerc
nosetests.xml
test-results/
test-reports/

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# ── Linting / formatting ──────────────────────────────────────────────────────
.ruff_cache/

# ── IDE / editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
log/

# ── Uploads / temp files ──────────────────────────────────────────────────────
uploads/
tmp/
temp/
*.tmp

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore

# ── Jupyter Notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
